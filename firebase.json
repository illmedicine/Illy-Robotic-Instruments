{
  "hosting": {
    "public": "site-next/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": false,
    "trailingSlash": true,
    "redirects": [
      { "source": "/livepay", "destination": "https://illmedicine.github.io/LivePay/", "type": 302 },
      { "source": "/livepay/**", "destination": "https://illmedicine.github.io/LivePay/", "type": 302 }
    ],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/isocial/**", "destination": "/isocial/index.html" },
      { "source": "/IR-AIcademy/**", "destination": "/IR-AIcademy/index.html" }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  }
}
